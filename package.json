{
  "name": "localoco",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:generate": "pnpm load-env @better-auth/cli generate --output apps/server/database/auth-schema.ts --config apps/frontend/src/lib/auth.ts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint",
    "format:fix": "oxfmt --write",
    "format:check": "oxfmt --check",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "clean": "rimraf node_modules .tanstack coverage .vite build dist"
  },
  "dependencies": {
    "better-auth": "catalog:",
    "vitest": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "catalog:",
    "cross-env": "catalog:",
    "dotenv": "catalog:",
    "dotenv-cli": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "rimraf": "catalog:",
    "ts-node": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "overrides": {
    "kysely": "0.28.10"
  },
  "engines": {
    "bun": ">=1.3.0",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "hono@<4.12.4": "^4.12.4",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "^10.2.3",
      "minimatch@<3.1.4": "^3.1.4",
      "rollup@<4.59.0": "^4.59.0"
    }
  }
}
