{
  "name": "@localoco/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot index.ts",
    "build": "bun build ./index.ts --outdir ./dist --target bun",
    "lint": "pnpm oxlint --config oxlint.config.ts --quiet",
    "load-env": "dotenv -e .env",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "bun run load-env -- bun drizzle-kit generate",
    "db:push": "bun run load-env -- bun drizzle-kit push",
    "db:pull": "bun run load-env -- bun drizzle-kit pull",
    "db:studio": "bun run load-env -- bun drizzle-kit studio"
  },
  "dependencies": {
    "@cloudamqp/amqp-client": "^3.4.1",
    "@localoco/shared": "workspace:*",
    "@logtail/pino": "^0.5.8",
    "@sentry/node": "^10.48.0",
    "@supabase/supabase-js": "^2.103.0",
    "@t3-oss/env-core": "^0.13.11",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.37.0",
    "better-auth": "catalog:",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.12",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.10.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.10.7",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/amqplib": "^0.10.8",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-istanbul": "catalog:",
    "dotenv": "catalog:",
    "dotenv-cli": "catalog:",
    "drizzle-kit": "^0.31.10",
    "hono-openapi": "^1.3.0",
    "ioredis": "^5.10.1",
    "testcontainers": "^11.14.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
