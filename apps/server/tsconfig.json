{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["bun"],
    "noUncheckedIndexedAccess": true,
    "outDir": "./build",
    "paths": {
      "@server/*": ["./*"],
      "@shared/*": ["../../shared/*"],
      "@server/env": ["./env.ts"]
    },
    "rootDir": "../../"
  },
  "include": [".", "../../shared", "../../oxlint.config.ts"],
  "exclude": ["node_modules", "build", "tests"]
}
